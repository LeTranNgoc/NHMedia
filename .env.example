# =================================
# Backend env
# =================================

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/translate-voice

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Magic Link (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Speech-to-Text
DEEPGRAM_API_KEY=

# Translation
GEMINI_API_KEY=

# Text-to-Speech (Google Cloud)
GOOGLE_CLOUD_TTS_KEY_FILE=./secrets/gcp-tts-service-account.json

# Billing (Polar.sh)
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_PRO=

# =================================
# Extension env (used at build time)
# =================================

VITE_BACKEND_WS_URL=ws://localhost:3000/ws/translate
VITE_BACKEND_API_URL=http://localhost:3000
