# =================================
# Backend env
# =================================

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/translate-voice

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Magic Link (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Magic link base URL — backend's own public URL, used in email links.
# Dev: http://localhost:3000
# Prod: https://api.your-domain.com
MAGIC_LINK_BASE_URL=http://localhost:3000

# Google OAuth (client ID/secret from GCP Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated Chrome extension IDs allowed to bridge OAuth/magic-link.
# Empty in dev = allow any extension (relaxed mode).
# Get the ID from chrome://extensions after Load Unpacked.
ALLOWED_EXTENSION_IDS=

# CORS allowed origins (comma-separated). Default allows any chrome-extension://*.
CORS_ORIGINS=chrome-extension://*

# Speech-to-Text
DEEPGRAM_API_KEY=

# Translation
# Provider selection: 'azure' (default) or 'gemini'. Falls back to Gemini if Azure key absent.
TRANSLATE_PROVIDER=azure
GEMINI_API_KEY=
# Azure Cognitive Services Translator (F0 free tier: 2M chars/hour)
# Get key from: Azure Portal → Cognitive Services → Translator → Keys
AZURE_TRANSLATOR_KEY=

# Text-to-Speech (Google Cloud)
GOOGLE_CLOUD_TTS_KEY_FILE=./secrets/gcp-tts-service-account.json

# Text-to-Speech (Azure Cognitive Services — fallback for langs not in Cloud Neural2)
# Get key from: Azure Portal → Cognitive Services → Speech → Keys and Endpoint
# Region must match the TTS endpoint (e.g. southeastasia, eastus, westus)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# Free tier usage caps (daily, per user)
# Prod defaults: SECONDS=900 (15 min), TRANSLATE_CHARS=50000, TTS_CHARS=50000
# Dev overrides below allow extended testing without hitting real caps.
FREE_TIER_LIMIT_SECONDS=36000
FREE_TIER_LIMIT_TRANSLATE_CHARS=50000
FREE_TIER_LIMIT_TTS_CHARS=50000

# Free-tier abuse guard — block new sign-up when this many user records
# already share the same device fingerprint (IP + UA + extension ID hash).
# Set to 0 to disable (dev). Recommended prod: 3.
MAX_ACCOUNTS_PER_FINGERPRINT=3

# Redis URL for cross-process rate-limiting (sign-up + magic-link throttle).
# Empty = in-memory (single-process, dev/test default).
# Upstash free tier: 10k commands/day covers closed beta easily.
# Example: redis://default:<password>@<region>-<id>.upstash.io:6379
REDIS_URL=

# Observability — leave empty to disable
# Sentry: error tracking. Get DSN from sentry.io → Project → Settings → Client Keys.
SENTRY_DSN=
# Logtail (Better Stack): log aggregation. Source token from betterstack.com.
LOGTAIL_SOURCE_TOKEN=
# Optional release tag for Sentry source maps (e.g. $GIT_SHA in CI).
APP_RELEASE=

# Billing (Polar.sh)
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_PRO=
# Hosted checkout link from Polar dashboard → Products → your Pro product → Checkout Links.
# Example: https://buy.polar.sh/your-org/your-product
# Used by GET /billing/checkout-url — customer_external_id + customer_email appended server-side.
POLAR_PRO_CHECKOUT_URL=
# Polar environment: 'sandbox' for sandbox.polar.sh, 'production' for live polar.sh.
# Token + product must be created in the matching environment.
POLAR_SERVER=sandbox

# =================================
# Extension env (used at build time)
# =================================

VITE_BACKEND_WS_URL=ws://localhost:3000/ws/translate
VITE_BACKEND_API_URL=http://localhost:3000

# Sentry DSN for extension surfaces (SW, offscreen, popup). Leave empty to disable.
WXT_SENTRY_DSN=
# Optional release tag inlined into the build for Sentry source-map matching.
WXT_APP_RELEASE=
