# Environment secrets — NEVER commit
.env
# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
# Local plan reports (user-private, not shipped)
plans/reports/*.local.md

# Runtime logs (generated per-session, not shipped)
hook-log.jsonl
session-state/
agent-memory/

# Skill telemetry (local usage data — opt-out via .claude-config.json)
telemetry/

# Python venvs created by skills (per-user, rebuildable)
skills/.venv/
skills/**/.venv/
skills/**/__pycache__/
skills/**/*.pyc

# Eval run artifacts (specs ship, run outputs don't)
evals/runs/
evals/**/*.local.json

# Local config overrides (user-specific, should not overwrite shipped defaults)
.claude-config.local.json
*.local.json

# Caches
.cache/