{
  "name": "translate-voice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Chrome MV3 extension lồng tiếng Việt real-time cho YouTube",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm -r test",
    "dev:backend": "pnpm -F backend dev",
    "dev:extension": "pnpm -F extension dev",
    "setup": "node scripts/setup.cjs",
    "check-env": "node scripts/check-env.cjs",
    "gen:secret": "node scripts/gen-jwt-secret.cjs",
    "vad:download": "node scripts/download-vad-model.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
