# WXT environment variables — copy to .env and fill in for your target environment.
# Dev defaults (localhost) are baked in as fallbacks; these vars only needed for prod builds.

# WebSocket URL for the translation backend
# Dev default: ws://localhost:3001/ws
# Prod example: wss://api.translate-voice.example/ws/translate
WXT_WS_URL=wss://api.translate-voice.example/ws/translate

# REST API base URL for billing endpoints
# Dev default: http://localhost:3000
# Prod example: https://api.translate-voice.example
WXT_API_BASE=https://api.translate-voice.example
